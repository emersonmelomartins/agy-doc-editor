# API server
PORT=3333
HOST=0.0.0.0

# SQLite (source of truth)
# local dev path (inside apps/api)
SQLITE_PATH=./docsi.db

# Supabase sync (optional)
# Leave both empty to disable sync.
# Get in Supabase Dashboard > Project Settings > API.
# Example for your project id: https://nauehcvoaipyxrhjtogc.supabase.co
# Use publishable/anon key here (never secret key).
SUPABASE_URL=
SUPABASE_ANON_KEY=
