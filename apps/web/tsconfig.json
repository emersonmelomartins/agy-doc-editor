{
  "extends": "../../packages/tsconfig/base.json",
  "compilerOptions": {
    "strict": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "kubb.config.ts"],
  "exclude": ["node_modules", "dist", "src/lib/api-client/generated.ts"]
}
